<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:orientation="vertical"
    android:fitsSystemWindows="false">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:elevation="1dp"
            app:navigationIcon="@drawable/ic_baseline_menu_24"/>

        <include
            android:id="@+id/search"
            layout="@layout/include_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_marginStart="18dp"
            android:layout_marginTop="72dp"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="72dp"
            android:gravity="center_vertical"
            android:lines="1"
            android:padding="8dp"
            android:paddingStart="8dp"
            android:textSize="18sp" />

        <include
            android:id="@+id/map_container"
            layout="@layout/map_container"
            android:layout_height="match_parent"
            android:layout_width="match_parent"/>

        <!-- ============ WALK MODE BOTTOM PANEL ============ -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/walk_controls_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp"
            android:elevation="12dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Status / Hint -->
                <TextView
                    android:id="@+id/walk_hint_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tap peta untuk titik START"
                    android:textAlignment="center"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:paddingBottom="12dp" />

                <!-- Speed Slider Section -->
                <LinearLayout
                    android:id="@+id/walk_speed_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- Speed label row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingBottom="4dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_baseline_directions_walk_24"
                            android:contentDescription="Speed icon" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Kecepatan"
                            android:textSize="13sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:paddingStart="8dp" />

                        <TextView
                            android:id="@+id/speed_value_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5 km/h"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorPrimary" />

                    </LinearLayout>

                    <!-- Slider -->
                    <com.google.android.material.slider.Slider
                        android:id="@+id/speed_slider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="1"
                        android:valueTo="80"
                        android:value="5"
                        android:stepSize="1"
                        app:labelBehavior="gone"
                        app:trackHeight="6dp"
                        app:thumbRadius="10dp" />

                    <!-- Speed range labels -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="1 km/h"
                            android:textSize="11sp"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="80 km/h"
                            android:textSize="11sp"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Action Buttons Row -->
                <LinearLayout
                    android:id="@+id/walk_action_buttons"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:visibility="gone"
                    android:paddingTop="4dp">

                    <!-- Reset/Stop button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_walk_stop"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="Reset"
                        app:icon="@drawable/ic_stop"
                        app:iconGravity="textStart"
                        app:iconSize="20dp" />

                    <!-- Play/Pause button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_walk_play"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1.5"
                        android:layout_marginStart="8dp"
                        android:text="Mulai"
                        app:icon="@drawable/ic_play"
                        app:iconGravity="textStart"
                        app:iconSize="20dp" />

                </LinearLayout>

                <!-- Progress Section -->
                <LinearLayout
                    android:id="@+id/walk_progress_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:paddingTop="12dp">

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/walk_progress_bar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:indeterminate="false"
                        android:max="100"
                        android:progress="0"
                        app:trackThickness="8dp"
                        app:trackCornerRadius="4dp" />

                    <TextView
                        android:id="@+id/walk_progress_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textAlignment="center"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:paddingTop="6dp" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ============ END WALK MODE UI ============ -->

        <!-- Mode Toggle: bottom-left -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mode_toggle_card"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentBottom="true"
            android:layout_marginStart="12dp"
            android:layout_marginBottom="12dp"
            android:elevation="8dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:strokeWidth="0dp">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/mode_toggle_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="4dp"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_normal"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Normal"
                    android:checked="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_walk"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Walk"
                    app:chipIcon="@drawable/ic_baseline_directions_walk_24" />

            </com.google.android.material.chip.ChipGroup>

        </com.google.android.material.card.MaterialCardView>

        <!-- Right side FABs (normal mode) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/getlocation"
            style="@style/Widget.Material3.Button.TonalButton"
            android:contentDescription="@string/getlocation_desc"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:alpha="0.95"
            android:elevation="10dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_baseline_my_location_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="32dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/addfavorite"
            style="@style/Widget.Material3.Button.TonalButton"
            android:contentDescription="@string/addfavorite_desc"
            android:layout_above="@id/getlocation"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_alignParentEnd="true"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="16dp"
            android:alpha="0.95"
            android:elevation="10dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_baseline_favorite"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="32dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/favorite_list"
            style="@style/Widget.Material3.Button.TonalButton"
            android:contentDescription="@string/favorites"
            android:layout_above="@id/addfavorite"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_alignParentEnd="true"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="16dp"
            android:alpha="0.95"
            android:elevation="10dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_outline_favorite_list"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="32dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/start_button"
            android:contentDescription="@string/location_set"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_above="@id/favorite_list"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_alignParentEnd="true"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:alpha="0.95"
            android:elevation="10dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_play"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="32dp"
            android:visibility="visible" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/stop_button"
            android:contentDescription="@string/location_unset"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_above="@id/favorite_list"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_alignParentEnd="true"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:alpha="0.95"
            android:elevation="10dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_stop"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="32dp"
            android:visibility="gone" />

    </RelativeLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/drawer_header"
        app:menu="@menu/main_menu">
    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>

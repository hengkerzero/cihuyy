<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:orientation="vertical"
    android:fitsSystemWindows="false">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:elevation="1dp"
            app:navigationIcon="@drawable/ic_baseline_menu_24"/>

        <include
            android:id="@+id/search"
            layout="@layout/include_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_marginStart="18dp"
            android:layout_marginTop="72dp"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="72dp"
            android:gravity="center_vertical"
            android:lines="1"
            android:padding="8dp"
            android:paddingStart="8dp"
            android:textSize="18sp" />

        <include
            android:id="@+id/map_container"
            layout="@layout/map_container"
            android:layout_height="match_parent"
            android:layout_width="match_parent"/>

        <!-- ============ BOTTOM BAR: Normal | Walk + tombol aksi tengah ============ -->
        <LinearLayout
            android:id="@+id/bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_alignParentBottom="true"
            android:background="@color/map_bottom_bar"
            android:elevation="6dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <!-- Segmen NORMAL (kiri) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/chip_normal"
                style="@style/ModeToggleButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:text="@string/mode_normal"
                app:icon="@drawable/ic_baseline_my_location_24" />

            <!-- Tombol aksi utama (Play/Stop) — TENGAH, dipakai mode Normal & Walk -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/center_action"
                style="@style/MapFab"
                android:contentDescription="@string/location_set"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:elevation="0dp"
                app:backgroundTint="@color/map_fab_start"
                app:icon="@drawable/ic_play" />

            <!-- Segmen WALK (kanan) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/chip_walk"
                style="@style/ModeToggleButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:text="@string/mode_walk"
                app:icon="@drawable/ic_baseline_directions_walk_24" />

        </LinearLayout>

        <!-- ============ WALK MODE PANEL (di atas bottom bar) ============ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/walk_controls_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_above="@id/bottom_bar"
            android:layout_alignParentStart="true"
            android:layout_alignParentEnd="true"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp"
            android:elevation="6dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Status / Hint -->
                <TextView
                    android:id="@+id/walk_hint_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tap peta untuk titik START"
                    android:textAlignment="center"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:paddingBottom="12dp" />

                <!-- Baris kontrol waypoint: Loop (full width) + Undo/Reset -->
                <LinearLayout
                    android:id="@+id/walk_waypoint_controls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Loop sebagai list-item: teks kiri + switch kanan -->
                    <LinearLayout
                        android:id="@+id/walk_loop_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/walk_loop"
                                android:textSize="15sp"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/walk_loop_desc"
                                android:textSize="12sp"
                                android:textColor="?attr/colorOnSurfaceVariant" />

                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_walk_loop"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:focusable="false" />

                    </LinearLayout>

                    <!-- Undo + Reset: dua tombol selebar sama -->
                    <LinearLayout
                        android:id="@+id/walk_action_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="8dp"
                        android:baselineAligned="false">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_walk_undo"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:text="@string/walk_undo"
                            app:icon="@drawable/ic_refresh"
                            app:iconGravity="textStart"
                            android:visibility="gone" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_walk_reset"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="@string/walk_reset"
                            app:icon="@drawable/ic_delete"
                            app:iconGravity="textStart"
                            android:visibility="gone" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Ringkasan rute: Jarak · Estimasi · Titik (muncul saat rute siap) -->
                <LinearLayout
                    android:id="@+id/walk_stats_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:baselineAligned="false"
                    android:paddingTop="12dp"
                    android:paddingBottom="4dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/walk_stat_distance_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="–"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorPrimary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/walk_stat_distance"
                            android:textSize="11sp"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/walk_stat_eta_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="–"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorPrimary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/walk_stat_eta"
                            android:textSize="11sp"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/walk_stat_points_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorPrimary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/walk_stat_points"
                            android:textSize="11sp"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Speed Slider Section -->
                <LinearLayout
                    android:id="@+id/walk_speed_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="4dp"
                    android:visibility="gone">

                    <!-- Speed label row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/param_speed"
                            android:textSize="13sp"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <TextView
                            android:id="@+id/speed_value_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5 km/h"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorPrimary" />

                    </LinearLayout>

                    <!-- Slider -->
                    <com.google.android.material.slider.Slider
                        android:id="@+id/speed_slider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="1"
                        android:valueTo="80"
                        android:value="5"
                        android:stepSize="1"
                        app:labelBehavior="gone"
                        app:trackHeight="6dp"
                        app:thumbRadius="10dp" />

                </LinearLayout>

                <!-- Progress Section -->
                <LinearLayout
                    android:id="@+id/walk_progress_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:paddingTop="8dp">

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/walk_progress_bar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:indeterminate="false"
                        android:max="100"
                        android:progress="0"
                        app:trackThickness="6dp"
                        app:trackCornerRadius="3dp" />

                    <TextView
                        android:id="@+id/walk_progress_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textAlignment="center"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:paddingTop="4dp" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ============ END WALK MODE UI ============ -->

        <!-- ============ LEFT COLUMN FABs (sejajar dari bawah) ============ -->
        <LinearLayout
            android:id="@+id/left_fab_column"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentStart="true"
            android:layout_above="@id/bottom_bar"
            android:layout_marginStart="12dp"
            android:layout_marginBottom="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/settings_button"
                style="@style/MapFab"
                android:contentDescription="@string/settings_desc"
                android:layout_marginBottom="12dp"
                app:icon="@drawable/ic_outline_settings_24" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/addfavorite"
                style="@style/MapFab"
                android:contentDescription="@string/addfavorite_desc"
                android:layout_marginBottom="12dp"
                app:icon="@drawable/ic_baseline_favorite" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/favorite_list"
                style="@style/MapFab"
                android:contentDescription="@string/favorites_list_desc"
                app:icon="@drawable/ic_outline_favorite_list" />

        </LinearLayout>

        <!-- ============ RIGHT COLUMN FABs (sejajar dari bawah) ============ -->
        <LinearLayout
            android:id="@+id/right_fab_column"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentEnd="true"
            android:layout_above="@id/bottom_bar"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/refresh_maps"
                style="@style/MapFab"
                android:contentDescription="@string/refresh_maps_desc"
                android:layout_marginBottom="12dp"
                app:icon="@drawable/ic_refresh" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/delete_marker"
                style="@style/MapFab"
                android:contentDescription="@string/delete_marker_desc"
                android:layout_marginBottom="12dp"
                app:icon="@drawable/ic_delete" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/getlocation"
                style="@style/MapFab"
                android:contentDescription="@string/getlocation_desc"
                app:icon="@drawable/ic_baseline_my_location_24" />

        </LinearLayout>

    </RelativeLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/drawer_header"
        app:menu="@menu/main_menu">
    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>

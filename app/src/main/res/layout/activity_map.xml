<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:orientation="vertical"
    android:fitsSystemWindows="false">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:elevation="1dp"
            app:navigationIcon="@drawable/ic_baseline_menu_24"/>

        <include
            android:id="@+id/search"
            layout="@layout/include_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_marginStart="18dp"
            android:layout_marginTop="72dp"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="72dp"
            android:gravity="center_vertical"
            android:lines="1"
            android:padding="8dp"
            android:paddingStart="8dp"
            android:textSize="18sp" />

        <include
            android:id="@+id/map_container"
            layout="@layout/map_container"
            android:layout_height="match_parent"
            android:layout_width="match_parent"/>

        <!-- ============ WALK MODE BOTTOM PANEL ============ -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/walk_controls_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp"
            android:elevation="12dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Status / Hint -->
                <TextView
                    android:id="@+id/walk_hint_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tap peta untuk titik START"
                    android:textAlignment="center"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:paddingBottom="12dp" />

                <!-- Speed Slider Section -->
                <LinearLayout
                    android:id="@+id/walk_speed_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- Speed label row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingBottom="4dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_baseline_directions_walk_24"
                            android:contentDescription="Speed icon" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Kecepatan"
                            android:textSize="13sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:paddingStart="8dp" />

                        <TextView
                            android:id="@+id/speed_value_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5 km/h"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorPrimary" />

                    </LinearLayout>

                    <!-- Slider -->
                    <com.google.android.material.slider.Slider
                        android:id="@+id/speed_slider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="1"
                        android:valueTo="80"
                        android:value="5"
                        android:stepSize="1"
                        app:labelBehavior="gone"
                        app:trackHeight="6dp"
                        app:thumbRadius="10dp" />

                    <!-- Speed range labels -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="1 km/h"
                            android:textSize="11sp"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="80 km/h"
                            android:textSize="11sp"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Action Buttons Row -->
                <LinearLayout
                    android:id="@+id/walk_action_buttons"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:visibility="gone"
                    android:paddingTop="4dp">

                    <!-- Reset/Stop button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_walk_stop"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="Reset"
                        app:icon="@drawable/ic_stop"
                        app:iconGravity="textStart"
                        app:iconSize="20dp" />

                    <!-- Play/Pause button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_walk_play"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1.5"
                        android:layout_marginStart="8dp"
                        android:text="Mulai"
                        app:icon="@drawable/ic_play"
                        app:iconGravity="textStart"
                        app:iconSize="20dp" />

                </LinearLayout>

                <!-- Progress Section -->
                <LinearLayout
                    android:id="@+id/walk_progress_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:paddingTop="12dp">

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/walk_progress_bar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:indeterminate="false"
                        android:max="100"
                        android:progress="0"
                        app:trackThickness="8dp"
                        app:trackCornerRadius="4dp" />

                    <TextView
                        android:id="@+id/walk_progress_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textAlignment="center"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:paddingTop="6dp" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ============ END WALK MODE UI ============ -->

        <!-- ============ AUTO-OFF ON ORDER TOGGLE ============ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/auto_off_card"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_above="@id/mode_toggle_button"
            android:layout_marginStart="12dp"
            android:layout_marginBottom="8dp"
            android:elevation="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="8dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auto-Off Order"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurface" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_auto_off_order"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:checked="false" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ============ MODE TOGGLE (Normal / Walk) : bottom-left pill ============ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/mode_toggle_button"
            style="@style/Widget.Material3.Button.TonalButton"
            android:contentDescription="@string/mode_toggle_desc"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentBottom="true"
            android:layout_marginStart="12dp"
            android:layout_marginBottom="12dp"
            android:elevation="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/mode_normal"
            android:textColor="@color/map_fab_icon"
            app:backgroundTint="@color/map_fab_background"
            app:cornerRadius="28dp"
            app:icon="@drawable/ic_baseline_directions_walk_24"
            app:iconGravity="textStart"
            app:iconSize="22dp"
            app:iconTint="@color/map_fab_icon"
            app:rippleColor="#33FFFFFF" />

        <!-- ============ LEFT COLUMN FABs ============ -->
        <LinearLayout
            android:id="@+id/left_fab_column"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentStart="true"
            android:layout_above="@id/mode_toggle_button"
            android:layout_marginStart="12dp"
            android:layout_marginBottom="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/settings_button"
                style="@style/MapFab"
                android:contentDescription="@string/settings_desc"
                android:layout_marginBottom="12dp"
                app:icon="@drawable/ic_outline_settings_24" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/addfavorite"
                style="@style/MapFab"
                android:contentDescription="@string/addfavorite_desc"
                android:layout_marginBottom="12dp"
                app:icon="@drawable/ic_baseline_favorite" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/favorite_list"
                style="@style/MapFab"
                android:contentDescription="@string/favorites_list_desc"
                app:icon="@drawable/ic_outline_favorite_list" />

        </LinearLayout>

        <!-- ============ RIGHT COLUMN FABs ============ -->
        <LinearLayout
            android:id="@+id/right_fab_column"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/refresh_maps"
                style="@style/MapFab"
                android:contentDescription="@string/refresh_maps_desc"
                android:layout_marginBottom="12dp"
                app:icon="@drawable/ic_refresh" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/delete_marker"
                style="@style/MapFab"
                android:contentDescription="@string/delete_marker_desc"
                android:layout_marginBottom="12dp"
                app:icon="@drawable/ic_delete" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/start_button"
                style="@style/MapFab"
                android:contentDescription="@string/location_set"
                android:layout_marginBottom="12dp"
                app:backgroundTint="@color/map_fab_start"
                app:icon="@drawable/ic_play"
                android:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/stop_button"
                style="@style/MapFab"
                android:contentDescription="@string/location_unset"
                android:layout_marginBottom="12dp"
                app:backgroundTint="@color/map_fab_stop"
                app:icon="@drawable/ic_stop"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/getlocation"
                style="@style/MapFab"
                android:contentDescription="@string/getlocation_desc"
                app:icon="@drawable/ic_baseline_my_location_24" />

        </LinearLayout>

    </RelativeLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/drawer_header"
        app:menu="@menu/main_menu">
    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>
